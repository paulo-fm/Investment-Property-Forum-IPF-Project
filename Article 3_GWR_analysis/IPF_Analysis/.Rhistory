# Load necessary libraries
library(tidyverse)
library(sf)
library(spdep)
library(spatialreg)
library(tmap)
library(vtable)
library(gtsummary)
# 1. Load your Master Data
df <- read.csv("../Thames_Estuary_Master.csv")
df$log_price <- log(df$Price)
# 2. Ensure factors are correctly typed for the model
df$property_type <- as.factor(df$Property.Type)
df$energy_rating <- as.factor(df$CURRENT_ENERGY_RATING)
# 3. Rename newly merged variables for cleaner tables
df <- df %>%
rename(
income_after_housing = `Disposable..net..annual.income.after.housing.costs....`,
travel_time_employment = `X100EmpPTt`,
elevation = elevation_m
)
df %>%
select(Price, log_price, TOTAL_FLOOR_AREA, income_after_housing,
travel_time_employment, HighRiskZone, elevation, PROPERTY_TYPE, CURRENT_ENERGY_RATING) %>%
tbl_summary(
statistic = list(all_continuous() ~ "{mean} ({sd})",
all_categorical() ~ "{n} ({p}%)"),
digits = all_continuous() ~ 2
) %>%
bold_labels()
install.packages("xfun", type = "binary")
library(gtsummary)
library(tidyverse)
library(sf)
library(spdep)
library(spatialreg)
library(tmap)
library(vtable)
# 1. Load your Master Data
df <- read.csv("../Thames_Estuary_Master.csv")
df$log_price <- log(df$Price)
# 2. Ensure factors are correctly typed for the model
df$property_type <- as.factor(df$Property.Type)
df$energy_rating <- as.factor(df$CURRENT_ENERGY_RATING)
# 3. Rename newly merged variables for cleaner tables
df <- df %>%
rename(
income_after_housing = `Disposable..net..annual.income.after.housing.costs....`,
travel_time_employment = `X100EmpPTt`,
elevation = elevation_m
)
df %>%
select(Price, log_price, TOTAL_FLOOR_AREA, income_after_housing,
travel_time_employment, HighRiskZone, elevation, PROPERTY_TYPE, CURRENT_ENERGY_RATING) %>%
tbl_summary(
statistic = list(all_continuous() ~ "{mean} ({sd})",
all_categorical() ~ "{n} ({p}%)"),
digits = all_continuous() ~ 2
) %>%
bold_labels()
