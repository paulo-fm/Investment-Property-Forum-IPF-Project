# =================== Table 4: Spatial Errors ====================

library(spdep)

# 1. Clean and convert coordinates to a strictly numeric matrix
# Ensure we use the original Easting/Northing columns from your join
coords <- df %>%
  select(oseast1m_x, osnrth1m_x) %>%
  mutate(across(everything(), ~as.numeric(as.character(.)))) %>%
  as.matrix()

# 2. Check for any NA values that might have been created during conversion
if(any(is.na(coords))) {
  print("Warning: NA coordinates found. Removing rows with missing spatial data.")
  df <- df[!is.na(df$oseast1m) & !is.na(df$osnrth1m), ]
  coords <- as.matrix(df[, c("oseast1m", "osnrth1m")])
}

# 1. Add a tiny amount of 'jitter' to handle identical points (flats in same building)
# 0.01 meters is enough to separate points without affecting spatial accuracy
coords_jittered <- jitter(coords, amount = 0.01)

# 2. Run knearneigh again with the jittered coordinates
knn <- knearneigh(coords_jittered, k = 8)
nb <- knn2nb(knn)
lw <- nb2listw(nb, style = "W")

print("Spatial weights matrix successfully created.")


# 2. Run the Global OLS Model (Baseline)
# Including your new structural and neighbourhood controls
ols_model <- lm(log_price ~ TOTAL_FLOOR_AREA + PROPERTY_TYPE + CURRENT_ENERGY_RATING +
                  income_after_housing + travel_time_employment + 
                  Risk_Level + elevation + dist_river_m + pmu, 
                data = df)

# 3. Perform Moran's I Test on OLS Residuals
# If p < 0.001, OLS is misspecified and spatial models are required
moran_results <- lm.morantest(ols_model, lw)
print(moran_results)




# 1. Create a "Clean" dataframe with no missing values for the model
df_clean <- df %>%
  select(log_price, TOTAL_FLOOR_AREA, PROPERTY_TYPE, CURRENT_ENERGY_RATING,
         income_after_housing, travel_time_employment, 
         Risk_Level, elevation, dist_river_m, pmu,
         oseast1m_x, osnrth1m_x) %>%
  drop_na() # This ensures the row count matches exactly

# 3. Re-create the Weights Matrix for the clean data only
coords_clean <- cbind(df_clean$oseast1m, df_clean$osnrth1m)
coords_jittered <- jitter(coords_clean, amount = 0.01)
knn_clean <- knearneigh(coords_jittered, k = 8)
nb_clean <- knn2nb(knn_clean)
lw_clean <- nb2listw(nb_clean, style = "W", zero.policy = TRUE)

# 4. Run the Moran's Test again
moran_results <- lm.morantest(ols_model_clean, lw_clean, zero.policy = TRUE)
print(moran_results)


# These test for spatial lag and spatial error dependencies
rs_tests <- lm.RStests(ols_model_clean, lw_clean, 
                       test = c("RSerr", "RSlag", "adjRSerr", "adjRSlag"))

print(summary(rs_tests))


# ============ Table 4: Comparism of OLS, SDM, SEM ==========

library(spatialreg)
library(spam)
library(Matrix)

# Define the full model formula
# log_price is your dependent variable
# Risk_Level (3-levels), income, and travel time are your key predictors
form <- log_price ~ TOTAL_FLOOR_AREA + PROPERTY_TYPE +
  income_after_housing + travel_time_employment + 
  Risk_Level + elevation + dist_river_m

# A. OLS Model (The non-spatial baseline)
ols_mod <- lm(form, data = df_clean)

# Rebuild the weights matrix as Symmetric (Binary)
# This allows the 'Matrix' method to handle the 73k rows without crashing
# 1. Force the neighbor list to be strictly symmetric
nb_sym <- make.sym.nb(nb_clean)
lw_sym_final <- nb2listw(nb_sym, style = "B", zero.policy = TRUE)

# B. Spatial Error Model (SEM)
# 1. Update the SEM model using Sparse Matrix (Matrix) approach
# This avoids creating the 31Gb dense matrix
sem_mod <- errorsarlm(
  formula(ols_mod), 
  data = df_clean, 
  listw = lw_sym_final, 
  method = "Matrix",       # Uses sparse matrix algebra
  zero.policy = TRUE
)

# C. Spatial Durbin Model (SDM)
# 2. Update the SDM model similarly
sdm_mod <- lagsarlm(
  formula(ols_mod), 
  data = df_clean, 
  listw = lw_sym_final, 
  method = "Matrix",       # Vital for datasets > 10k rows
  zero.policy = TRUE
)

# 3. Compare Model Fit for Table 4
summary(sem_mod)
summary(sdm_mod)

# Summary for Table 4 comparison
summary(ols_mod)
summary(sem_mod)
summary(sdm_mod)



# ========= GWR Coding =====================

library(GWmodel)

# 1. Convert your cleaned data to a Spatial Object
# We use the 'sp' format required by the GWmodel package
df_sp <- SpatialPointsDataFrame(coords = coords_clean, data = df_clean, 
                                proj4string = CRS("EPSG:27700"))

# 2. Select the optimal Bandwidth (This is computationally intensive)
# We use AICc to find the balance between model fit and complexity
bw_adaptive <- bw.gwr(log_price ~ TOTAL_FLOOR_AREA + PROPERTY_TYPE + 
                        income_after_housing + travel_time_employment + 
                        Risk_Level + elevation + dist_river_m, 
                      data = df_sp, 
                      approach = "AIC", 
                      kernel = "bisquare", 
                      adaptive = TRUE)

print(paste("Optimal Number of Neighbors (Bandwidth):", bw_adaptive))


# 1. Stop the current process (Esc) if it hasn't already terminated
# 2. Run the GWR model with the most stable 'optimal' bandwidth
gwr_model_final <- gwr.basic(log_price ~ TOTAL_FLOOR_AREA + PROPERTY_TYPE + 
                               income_after_housing + travel_time_employment + 
                               Risk_Level + elevation + dist_river_m, 
                             data = df_sp, 
                             bw = 10000,      # Rounded from your last successful iteration
                             kernel = "bisquare", 
                             adaptive = TRUE)

 # 3. Save the object immediately
saveRDS(gwr_model_final, "IPF_Thames_GWR_Result.rds")

# 4. Extract the Summary for Table 5
summary(gwr_model_final$SDF)


