# 1. Load your Master Data
df <- read.csv("../Thames_Estuary_Master.csv")

df$log_price <- log(df$Price)

# 2. Ensure factors are correctly typed for the model
df$property_type <- as.factor(df$Property.Type)
df$energy_rating <- as.factor(df$CURRENT_ENERGY_RATING)

# 3. Rename newly merged variables for cleaner tables
df <- df %>% 
  rename(
    income_after_housing = `Disposable..net..annual.income.after.housing.costs....`,
    travel_time_employment = `X100EmpPTt`,
    elevation = elevation_m
  )



# 3. Recode the flood_zone variable
df <- df %>%
  mutate(Risk_Level = case_when(
    flood_zone == "FZ3" ~ "High Risk (FZ3)",
    flood_zone == "FZ2" ~ "Medium Risk (FZ2)",
    TRUE ~ "No Risk" # Categorizes everything else as No Risk
  )) %>%
  # Convert to a factor with a logical order for the table
  mutate(Risk_Level = factor(Risk_Level, levels = c("No Risk", "Medium Risk (FZ2)", "High Risk (FZ3)")))

# 2. Update all variables to numeric where needed to avoid errors
df <- df %>%
  mutate(
    Price = as.numeric(Price),
    TOTAL_FLOOR_AREA = as.numeric(TOTAL_FLOOR_AREA),
    elevation_m = as.numeric(elevation),
    dist_river_m = as.numeric(dist_river_m),
    income_after_housing = as.numeric(income_after_housing),
    travel_time_employment = as.numeric(`travel_time_employment`)
  )


# Generate the stratified table
table1_final <- df %>%
  select(pmu, Price, TOTAL_FLOOR_AREA, PROPERTY_TYPE, CURRENT_ENERGY_RATING, income_after_housing, 
         travel_time_employment, Risk_Level, elevation, dist_river_m) %>%
  tbl_summary(
    by = pmu, 
    statistic = list(
      all_continuous() ~ "{mean} ({sd}) \n ({min}, {max})",
      all_categorical() ~ "{n} ({p}%)"
    ),
    digits = all_continuous() ~ 2,
    label = list(
      Price ~ "Sale Price (£)",
      TOTAL_FLOOR_AREA ~ "Floor Area (m2)",
      PROPERTY_TYPE ~ "Property Types",
      CURRENT_ENERGY_RATING ~ "Energy Ratings (A-E)",
      income_after_housing ~ "Net Annual Income (£)",
      travel_time_employment ~ "Travel Time (min)",
      Risk_Level ~ "Flood Risk Classification",
      elevation ~ "Elevation (m)",
      dist_river_m ~ "Distance to River (m)"
    )
  ) %>%
  add_overall() %>%
  modify_header(label = "**Variables**") %>%
  bold_labels()

# Display the table
table1_final


