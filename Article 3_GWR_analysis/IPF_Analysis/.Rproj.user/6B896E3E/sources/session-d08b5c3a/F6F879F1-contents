n_obs  <- length(sem_mod$residuals)
sem_r2_pseudo <- (1 - exp(-2/n_obs * (L_full - L_null))) / (1 - exp(2/n_obs * L_null))

# 4. Final Table Construction
table_5_final <- data.frame(
  Metric = c("AIC / AICc", "Adjusted / Pseudo R2", "FZ3 Impact (Beta)"),
  Global_SEM = c(round(sem_aic, 2), round(sem_r2_pseudo, 4), round(sem_beta, 4)),
  Local_GWR  = c(round(gwr_aicc, 2), round(gwr_r2_adj, 4), round(gwr_median_beta, 4))
)

print(table_5_final)